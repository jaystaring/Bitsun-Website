      "regex": "^/api/admin/demos/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPfileName": "nxtPfileName"
      },
      "namedRegex": "^/api/admin/demos/(?<nxtPfileName>[^/]+?)(?:/)?$"
    },
    {
