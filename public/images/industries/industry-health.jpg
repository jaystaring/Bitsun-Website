<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="healthGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00C2FF;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#00F5FF;stop-opacity:0.1" />
    </linearGradient>
    <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00F5FF;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#00C2FF;stop-opacity:0.4" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="#050810"/>
  
  <!-- Grid pattern -->
  <g opacity="0.1">
    <line x1="0" y1="0" x2="0" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="100" y1="0" x2="100" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="200" y1="0" x2="200" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="300" y1="0" x2="300" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="400" y1="0" x2="400" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="500" y1="0" x2="500" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="600" y1="0" x2="600" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="700" y1="0" x2="700" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="0" y1="100" x2="800" y2="100" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="0" y1="200" x2="800" y2="200" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="0" y1="300" x2="800" y2="300" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="0" y1="400" x2="800" y2="400" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="0" y1="500" x2="800" y2="500" stroke="#00C2FF" stroke-width="0.5"/>
  </g>
  
  <!-- Central glow -->
  <circle cx="400" cy="300" r="200" fill="url(#healthGrad)"/>
  <circle cx="400" cy="300" r="100" fill="url(#glowGrad)" opacity="0.5"/>
  
  <!-- Medical cross icon -->
  <g transform="translate(340, 240)">
    <rect x="20" y="0" width="80" height="120" rx="10" fill="none" stroke="#00F5FF" stroke-width="2"/>
    <rect x="0" y="40" width="120" height="40" rx="10" fill="none" stroke="#00F5FF" stroke-width="2"/>
  </g>
  
  <!-- Data flow lines -->
  <g opacity="0.6">
    <line x1="100" y1="150" x2="250" y2="200" stroke="#00F5FF" stroke-width="1"/>
    <line x1="550" y1="150" x2="700" y2="200" stroke="#00F5FF" stroke-width="1"/>
    <line x1="100" y1="450" x2="250" y2="400" stroke="#00F5FF" stroke-width="1"/>
    <line x1="550" y1="450" x2="700" y2="400" stroke="#00F5FF" stroke-width="1"/>
  </g>
  
  <!-- Pills/capsules icons -->
  <g opacity="0.4">
    <ellipse cx="150" cy="200" rx="30" ry="15" fill="none" stroke="#00C2FF" stroke-width="1"/>
    <ellipse cx="650" cy="200" rx="30" ry="15" fill="none" stroke="#00C2FF" stroke-width="1"/>
    <ellipse cx="150" cy="400" rx="30" ry="15" fill="none" stroke="#00C2FF" stroke-width="1"/>
    <ellipse cx="650" cy="400" rx="30" ry="15" fill="none" stroke="#00C2FF" stroke-width="1"/>
  </g>
  
  <!-- Text -->
  <text x="400" y="520" text-anchor="middle" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="#00F5FF">大健康</text>
</svg>
