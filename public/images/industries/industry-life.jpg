<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="lifeGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00C2FF;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#00F5FF;stop-opacity:0.1" />
    </linearGradient>
    <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00F5FF;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#00C2FF;stop-opacity:0.4" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="#050810"/>
  
  <!-- Grid pattern -->
  <g opacity="0.1">
    <line x1="0" y1="0" x2="0" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="100" y1="0" x2="100" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="200" y1="0" x2="200" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="300" y1="0" x2="300" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="400" y1="0" x2="400" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="500" y1="0" x2="500" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="600" y1="0" x2="600" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="700" y1="0" x2="700" y2="600" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="0" y1="100" x2="800" y2="100" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="0" y1="200" x2="800" y2="200" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="0" y1="300" x2="800" y2="300" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="0" y1="400" x2="800" y2="400" stroke="#00C2FF" stroke-width="0.5"/>
    <line x1="0" y1="500" x2="800" y2="500" stroke="#00C2FF" stroke-width="0.5"/>
  </g>
  
  <!-- Central glow -->
  <circle cx="400" cy="300" r="200" fill="url(#lifeGrad)"/>
  <circle cx="400" cy="300" r="100" fill="url(#glowGrad)" opacity="0.5"/>
  
  <!-- House icon -->
  <g transform="translate(350, 250)">
    <path d="M50 0 L100 50 L100 150 L0 150 L0 50 Z" fill="none" stroke="#00F5FF" stroke-width="2"/>
    <rect x="30" y="100" width="40" height="50" fill="none" stroke="#00F5FF" stroke-width="2"/>
    <rect x="80" y="100" width="40" height="50" fill="none" stroke="#00F5FF" stroke-width="2"/>
  </g>
  
  <!-- Delivery truck icon -->
  <g opacity="0.5">
    <rect x="120" y="180" width="80" height="40" rx="5" fill="none" stroke="#00C2FF" stroke-width="1"/>
    <circle cx="140" cy="230" r="8" fill="none" stroke="#00C2FF" stroke-width="1"/>
    <circle cx="180" cy="230" r="8" fill="none" stroke="#00C2FF" stroke-width="1"/>
    
    <rect x="600" y="180" width="80" height="40" rx="5" fill="none" stroke="#00C2FF" stroke-width="1"/>
    <circle cx="620" cy="230" r="8" fill="none" stroke="#00C2FF" stroke-width="1"/>
    <circle cx="660" cy="230" r="8" fill="none" stroke="#00C2FF" stroke-width="1"/>
  </g>
  
  <!-- Connection lines -->
  <g opacity="0.4">
    <path d="M200 300 Q300 280 400 300 Q500 320 600 300" fill="none" stroke="#00F5FF" stroke-width="1" stroke-dasharray="5,5"/>
    <path d="M200 350 Q300 330 400 350 Q500 370 600 350" fill="none" stroke="#00F5FF" stroke-width="1" stroke-dasharray="5,5"/>
  </g>
  
  <!-- Appliance icons -->
  <g opacity="0.3">
    <rect x="150" y="380" width="60" height="80" rx="5" fill="none" stroke="#00C2FF" stroke-width="1"/>
    <rect x="590" y="380" width="60" height="80" rx="5" fill="none" stroke="#00C2FF" stroke-width="1"/>
  </g>
  
  <!-- Text -->
  <text x="400" y="520" text-anchor="middle" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="#00F5FF">大生活</text>
</svg>
